{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "verbatimModuleSyntax": true,
    "paths": {
      "~assets/*": ["./src/assets/*"],
      "~layouts/*": ["./src/layouts/*"],
      "~pages/*": ["./src/pages/*"],
      "~styles/*": ["./src/styles/*"]
    },
    "jsx": "preserve"
  }
}
